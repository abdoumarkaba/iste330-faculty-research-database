# Faculty Research Database - Environment Configuration Template
# Copy this file to .env and update values for your environment
# DO NOT commit .env files to version control

# Database Configuration
DB_HOST=localhost
DB_PORT=3307
DB_NAME=faculty_research_db
DB_USER=your_database_user
DB_PASSWORD=your_secure_password

# Connection Pool Configuration (HikariCP)
# DB_POOL_SIZE: Maximum number of connections in the pool (default: 5)
# DB_CONNECTION_TIMEOUT: Maximum time to wait for a connection in milliseconds (default: 30000)
DB_POOL_SIZE=5
DB_CONNECTION_TIMEOUT=30000

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO

# Security Configuration
BCRYPT_ROUNDS=12
